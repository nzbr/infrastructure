{
    "compilerOptions": {
        "strict": true,
        "outDir": "bin",
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "pretty": true,
        "noImplicitReturns": true,
        "forceConsistentCasingInFileNames": true,
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "files": ["src/index.ts"]
}
